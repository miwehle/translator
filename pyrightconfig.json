{
  "include": ["src", "tests"],
  "exclude": [
    "**/__pycache__",
    ".pytest_tmp",
    "checkpoints",
    "pytest-cache-files-*"
  ],
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    }
  ],
  "typeCheckingMode": "basic",
  "reportMissingImports": "none",
  "reportMissingTypeStubs": "none",
  "pythonVersion": "3.13"
}
